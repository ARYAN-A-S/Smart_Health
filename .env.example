# Database Configuration
# For local development: sqlite:///backend/smart_health.db
DATABASE_URL=sqlite:///backend/smart_health.db

# Authentication Security
JWT_SECRET=supersecretjwtkeyforlocaldevelopmentonly12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Twilio Configuration (WhatsApp Intake)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# Bhashini API Configuration (Multilingual voice/text translation)
BHASHINI_USER_ID=your_bhashini_user_id
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_PIPELINE_ID=your_bhashini_pipeline_id
